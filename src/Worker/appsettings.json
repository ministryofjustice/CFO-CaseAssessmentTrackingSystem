{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Cfo": "Trace"
    }
  },
  "ConnectionStrings": {
    "CatsDb": "",
    "rabbit": ""
  },
  "Quartz": {
    "quartz.scheduler.instanceName": "CATS Worker Scheduler",
    "SyncParticipantsJob": {
      "Enabled": true,
      "CronSchedules": [
        {
          "Chron": "0 0 22 * * ? *",
          "Description": "Every night at 22:00"
        }
      ]
    },
    "DisableDormantAccountsJob": {
      "Enabled": true,
      "CronSchedules": [
        {
          "Chron": "0 0 19 * * ? *",
          "Description": "Every night at 19:00"
        }
      ]
    },
    "NotifyAccountDeactivationJob": {
      "Enabled": true,
      "CronSchedules": [
        {
          "Chron": "0 0 0 30 11 ? 2099",
          "Description": "Runs in the evening"
        }
      ]
    },
    "PublishOutboxMessagesJob": {
      "Enabled": true,
      "CronSchedules": [
        {
          "Chron": "0 5 0-6 * * ?",
          "Description": "00:00 till 06:00 every 10 minutes"
        },
        {
          "Chron": "0/5 * 7-19 * * ?",
          "Description": "07:00 till 19:00 every 5 seconds"
        },
        {
          "Chron": "0 5 20-23 * * ?",
          "Description": "20:00 till 00:00 every 10 minutes"
        }
      ]
    },
    "GenerateOutcomeQualityDipSamplesJob": {
      "Enabled": true,
      "CronSchedules": [
        {
          "Chron": "0 0 3 1 * ?",
          "Description": "Runs on the first of the month at 03:00"
        }
      ]
    },
    "ArchiveParticipantsJob": {
      "Enabled": true,
      "CronSchedules": [
        {
          "Chron": "0 0 22 * * ? *",
          "Description": "Every night at 22:00"
        }
      ]
    }
  },
  "RabbitSettings": {
    "TopicExchange": "CatsTopics",
    "DirectExchange": "CatsDirect",
    "Retries": 1,
    "DocumentService": "document-service",
    "PaymentService": "payment-service",
    "TasksService": "tasks-service",
    "OvernightService": "overnight-service"
  },
  "OvernightServiceSettings": {
    "Workers": 1,
    "Parallelism": 1
  },
  "AppConfigurationSettings": {
    "AppName": "CATS Worker"
  },
  "OutcomeQualityDipSampleSettings": {
    "Wing": 10,
    "Hub": 10,
    "Satellite": 5,
    "Community": 10,
    "WiderCustody": 10,
    "MonthOffset": -4
  }
}
