{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "MigrationBehaviour": "WaitForCompletion",
  "Features": {
    "UseWorkerForJobs": true,
    "Redis": {
      "Enabled": true,
      "SignalRBackplane": true,
      "SessionStore": true
    },
    "UseDmsHardLinkApi": true,
    "PresenceHub": {
      "Enabled": true,
      "RelayUserPresenceNotifications": true
    }
  }
}
