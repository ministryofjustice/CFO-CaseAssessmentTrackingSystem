{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "MigrationBehaviour": "WaitForCompletion",
  "Features": {
    "UseWorkerForJobs": true,
    "UseSignalRBackplane": true,
    "UseDmsHardLinkApi": true,
    "PresenceHub": {
      "Enabled": true,
      "RelayUserPresenceNotifications": true
    }
  }
}
