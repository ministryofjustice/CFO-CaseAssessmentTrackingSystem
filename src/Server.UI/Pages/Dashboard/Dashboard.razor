@page "/"
@using Cfo.Cats.Server.UI.Pages.Dashboard.Components
@using Cfo.Cats.Server.UI.Pages.Workspaces.DeliveryManagement.Components
@using Cfo.Cats.Server.UI.Pages.Workspaces.ServiceDesk.Pages.Sync.Components

@inherits CatsComponentBase

<MudText Typo="Typo.h3">
    @_title
</MudText>

<MudGrid Class="mt-2">

    @if (_showSearchParticipant)
    {
        <ParticipantById/>
    }
   
    @if (_showMyTeamsParticipants)
    {
        <MyTeamsParticipantsLatestEngagementComponent/>
    }
    else
    {
        <MyParticipantsLatestEngagementComponent/>
    }

</MudGrid>