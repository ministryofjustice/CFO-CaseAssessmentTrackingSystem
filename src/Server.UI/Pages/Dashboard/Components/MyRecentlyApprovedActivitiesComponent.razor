@using Cfo.Cats.Application.Features.Dashboard.DTOs;
@using Cfo.Cats.Domain.Common.Enums
@using Cfo.Cats.Server.UI.Components.Locations
@using Humanizer

@inherits CatsComponentBase

<MudItem xs="12" lg="6">
    @if (@_loading)
    {
        <LoadingCard Title="Recently Approved Activities" />
    }
    else
    {
        <MudCard style="height: 100%">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h5">Recently Approved Activities</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudList T="RecentlyApprovedActivitiesSummaryDto" ReadOnly>
                    <MudListSubheader>
                        <MudGrid>
                            <MudItem xs="12">
                                <MudDateRangePicker Label="Commenced from/to range"
                                                DateRangeChanged="@OnDateRangeChanged"
                                                Clearable
                                                MaxDate="DateTime.Today" />
                            </MudItem>
                            <MudItem xs="12">
                                <LocationSelectComponent
                                    TenantId="@(CurrentUser.TenantId!)"
                                    Label="Location"
                                    @bind-Value="_location"
                                    @bind-Value:after="OnRefresh"
                                    For="() => _location" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudChipSet T="ActivityType"
                                            SelectedValuesChanged="OnActivityTypesChanged"
                                            SelectionMode="SelectionMode.MultiSelection">
                                    @foreach (var type in ActivityType.List.Where(x=>x.Value == 1 || x.Value==2 || x.Value==4))
                                    {
                                        <MudChip Value="type"
                                                    SelectedColor="Color.Info"
                                                    Text="@type.Name" />
                                    }
                                </MudChipSet>
                            </MudItem>
                        </MudGrid>
                    </MudListSubheader>
                    @if (_activities is not null && _activities.Count > 0)
                    {
                        foreach (var activity in _activities)
                        {
                            var created = activity.Created;
                            var commencedOn = activity.CommencedOn;
                            var today = DateTime.Today.ToLocalTime();
                            
                            <MudListItem T="RecentlyApprovedActivitiesSummaryDto">
                                <div class="d-flex justify-space-between align-center w-100">
                                    <div>
                                        <MudText Typo="Typo.body2">
                                            Participant: @activity.Participant
                                            <MudButton Color="Color.Info" Variant="Variant.Text" Size="Size.Small" OnClick="@(() => EditParticipant(activity.ParticipantId))">
                                                @activity.ParticipantId
                                            </MudButton>
                                        </MudText>
                                        <div class="d-flex gap-2 align-center">
                                            <MudChip T="string" Size="MudBlazor.Size.Small" Text="@activity.Definition.Type.Name" Color="Color.Secondary" />
                                            <MudText Typo="Typo.body2">
                                                Category:  @activity.Definition.Category.Name.
                                            </MudText>
                                        </div>
                                        <MudText Typo="Typo.caption">
                                            Approved on: @activity.ApprovedOn?.ToString("d")
                                        </MudText>
                                        <MudText Typo="Typo.caption">
                                            Added on @created.ToShortDateOrEmptyString() (@(created?.Humanize() ?? "N/A")).
                                        </MudText>
                                        <MudText Typo="Typo.caption">
                                            Took place on @commencedOn.ToShortDateOrEmptyString() (@(commencedOn.HasValue && commencedOn.Value == today ? "today" : commencedOn?.Humanize() ?? "N/A"))
                                            at @activity.TookPlaceAtLocationName.
                                        </MudText>
                                    </div>
                            
                                </div>
                            </MudListItem>
                            <MudDivider />
                        }
                    }
                </MudList>            
            </MudCardContent>
        </MudCard>
    }
</MudItem>
