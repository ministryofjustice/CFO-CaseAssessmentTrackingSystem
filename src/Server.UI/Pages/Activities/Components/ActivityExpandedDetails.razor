@using Cfo.Cats.Application.Features.Activities.DTOs
@using Cfo.Cats.Application.Features.Activities.Queries
@using Humanizer

@inherits CatsComponentBase

<MudStack Class="pa-2">
    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Info" />
    }
    else
    {
        <MudText Typo="Typo.subtitle2">Notes</MudText>
        @if (_notes is { Length: > 0 })
        {
            @foreach (var note in _notes)
            {
                <MudTooltip Text="@note.Created.ToLocalTime().ToString("ddd, dd MMM yyyy 'at' HH:mm")">
                    <MudCard Outlined="true" Elevation="0" Class="mb-1">
                        <MudCardContent Class="py-2">
                            <MudText Typo="Typo.body2">@note.Message</MudText>
                            <MudText Typo="Typo.caption">
                                @note.CreatedBy (@note.TenantName)  @note.Created.Humanize()
                            </MudText>
                        </MudCardContent>
                    </MudCard>
                </MudTooltip>
            }
        }
        else
        {
            <MudText Typo="Typo.body2" Class="mud-text-secondary">No notes.</MudText>
        }
        <MudTextField Label="@Activity.GetMemberDescription(x => x.AdditionalInformation)"
                      Value="@Activity.AdditionalInformation"
                      Lines="5"
                      Class="mt-2"
                      ReadOnly />
    }
</MudStack>

@code {
    private bool _loading = true;
    private ActivityQaNoteDto[] _notes = [];

    [Parameter, EditorRequired]
    public required ActivityPaginationDto Activity { get; set; }

    [Parameter]
    public bool IncludeInternalNotes { get; set; }

    [Parameter, EditorRequired]
    public required UserProfile CurrentUser { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var result = await GetNewMediator().Send(new GetActivityQaNotes.Query
            {
                ActivityId = Activity.ActivityId,
                IncludeInternalNotes = IncludeInternalNotes,
                CurrentUser = CurrentUser
            });

            _notes = result is { Succeeded: true, Data: not null }
                ? result.Data.OrderBy(n => n.Created).ToArray()
                : [];
        }
        finally
        {
            _loading = false;
        }
    }
}
