@using Cfo.Cats.Application.Features.Activities.DTOs

<MudExpansionPanels Elevation="0" Class="mt-2">
    <MudExpansionPanel Text="Notes &amp; additional information"
                       ExpandedChanged="OnExpandedChanged">
        @if (_isExpanded)
        {
            <ActivityExpandedDetails Activity="Activity"
                                     IncludeInternalNotes="IncludeInternalNotes"
                                     CurrentUser="CurrentUser" />
        }
    </MudExpansionPanel>
</MudExpansionPanels>

@code {
    private bool _isExpanded;

    [Parameter, EditorRequired]
    public required ActivityPaginationDto Activity { get; set; }

    [Parameter]
    public bool IncludeInternalNotes { get; set; }

    [Parameter, EditorRequired]
    public required UserProfile CurrentUser { get; set; }

    private void OnExpandedChanged(bool expanded)
    {
        _isExpanded = expanded;
    }
}
