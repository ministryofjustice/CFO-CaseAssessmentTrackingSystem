@page "/pages/qa/activities/pqa"
@using Cfo.Cats.Application.Features.Activities.Commands
@using Cfo.Cats.Application.Features.Activities.DTOs
@using Cfo.Cats.Application.Features.Activities.Queries
@using Cfo.Cats.Application.SecurityConstants
@using Humanizer

@inherits OwningComponentBase<IMediator>

@inject IStringLocalizer<PQA> L
@inject ILogger<PqaList> Logger

@attribute [Authorize(Policy = SecurityPolicies.Pqa)]

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge">
    <MudStack>
        <MudStack Row="true" Justify="Justify.FlexEnd">
            <MudTextField T="string" Value="@Query.Keyword" Placeholder="@ConstantString.Search"
                          ValueChanged="@(OnSearch)" Clearable="true" ShrinkLabel="true"
                          AdornmentIcon="@Icons.Material.Filled.Search" Adornment="Adornment.Start"
                          AdornmentColor="Color.Secondary">
            </MudTextField>
            <MudSpacer />
            <MudLoadingButton Variant="Variant.Filled" Size="Size.Small"
                              Loading="@_loading"
                              OnClick="OnRefreshClicked"
                              StartIcon="@Icons.Material.Filled.Refresh"
                              Color="Color.Secondary">
                @ConstantString.Refresh
            </MudLoadingButton>
            <MudLoadingButton Loading="@_downloading"
                              Variant="Variant.Filled"
                              Color="Color.Secondary"
                              StartIcon="@Icons.Material.Filled.CloudDownload"
                              Size="Size.Small"
                              OnClick="OnExport">
                @ConstantString.Export
            </MudLoadingButton>
        </MudStack>

        <MudStack Row="true" Class="pt-4" Justify="Justify.FlexEnd" AlignItems="AlignItems.Center">
            <MudPagination
                Selected="Query.PageNumber"
                Count="@_totalPages"
                MiddleCount="2"
                BoundaryCount="1"
                SelectedChanged="PageChanged"
                Size="Size.Small">
            </MudPagination>

            <MudText>
                @_totalItems records
            </MudText>

            <MudSpacer />

            <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="ShowTenantDialog" EndIcon="@Icons.Material.Filled.KeyboardArrowDown">
                @if (string.IsNullOrEmpty(Query.TenantId))
                {
                    @("All Tenants")
                }
                else
                {
                    @_tenants[Query.TenantId]
                }
            </MudButton>

            <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="ShowSupportWorkerDialog" EndIcon="@Icons.Material.Filled.KeyboardArrowDown">
                @if (string.IsNullOrEmpty(Query.SupportWorkerId))
                {
                    @("All Assignees")
                }
                else
                {
                    @_users[Query.SupportWorkerId]
                }
            </MudButton>

            <MudMenu Size="Size.Small" Label="@SelectedActivityTypeName" EndIcon="@Icons.Material.Filled.KeyboardArrowDown">
                <MudMenuItem OnClick="@(() => ActivityTypeChanged(null))">All Activity Types</MudMenuItem>
                @foreach (var at in _availableActivityTypes)
                {
                    <MudMenuItem OnClick="@(() => ActivityTypeChanged(at.Value))">@at.Name</MudMenuItem>
                }
            </MudMenu>

            <MudMenu Size="Size.Small" Label="Sort By" EndIcon="@Icons.Material.Filled.KeyboardArrowDown">
                <MudMenuItem Label="Participant" OnClick="@(() => SortBy("ParticipantId"))" />
                <MudMenuItem Label="Support Worker" OnClick="@(() => SortBy("SupportWorker"))" />
                <MudMenuItem Label="Tenant" OnClick="@(() => SortBy("TenantId"))" />
                <MudMenuItem Label="Commenced On" OnClick="@(() => SortBy("CommencedOn"))" />
                <MudMenuItem Label="Submitted" OnClick="@(() => SortBy("Created"))" />
                <MudMenuItem Label="Expiry" OnClick="@(() => SortBy("Expiry"))" />
            </MudMenu>

            <MudTooltip Text="Clear search parameters">
                <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Clear" OnClick="@(() => ClearSearch())" />
            </MudTooltip>
        </MudStack>
    </MudStack>

    <MudTable T="ActivityQueueEntryDto" Items="@_data" Hover="true" Striped="true" SelectOnRowClick="true" OnRowClick="@OnRowClick">
        <HeaderContent>
            <MudTh>
                @L["Participant"]
            </MudTh>
            <MudTh>
                @L["Activity"]
            </MudTh>
            <MudTh>
                @L["Activity Type"]
            </MudTh>
            <MudTh>
                @L["Support Worker"]
            </MudTh>
            <MudTh>
                @L["Tenant"]
            </MudTh>
            <MudTh>
                @L["Commenced on"]
            </MudTh>
            <MudTh>
                @L["Submitted"]
            </MudTh>
            <MudTh>
                @L["Expiry"]
            </MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                <MudStack>
                    <MudText>
                        @context.ParticipantName
                    </MudText>
                    <MudText>
                        @context.ParticipantId
                    </MudText>
                </MudStack>
            </MudTd>
            <MudTd>
                <MudText>
                    @context.Activity.Definition.Category.Name
                </MudText>
            </MudTd>
            <MudTd>
                <MudText>
                    @context.Activity.Definition.Type.Name
                </MudText>
            </MudTd>
            <MudTd>
                <MudText>
                    @context.SupportWorker
                </MudText>
            </MudTd>
            <MudTd>
                <MudStack>
                    <MudText>@context.TenantName</MudText>
                    <MudText>@context.TenantId</MudText>
                </MudStack>
            </MudTd>
            <MudTd>
                <MudStack>
                    <MudText Typo="Typo.body2">
                        @context.CommencedOn.Date.ToString("d")
                    </MudText>
                    <MudText Typo="Typo.body2">
                        @context.CommencedOn.Date.Humanize()
                    </MudText>
                </MudStack>
            </MudTd>
            <MudTd>
                <MudStack>
                    <MudText Typo="Typo.body2">
                        @context.Created.Date.ToString("d")
                    </MudText>
                    <MudText Typo="Typo.body2">
                        @context.Created.Humanize()
                    </MudText>
                </MudStack>
            </MudTd>
            <MudTd>
                <MudTooltip Text="Must be processed up to 3 months after completion">
                    @if (context.Expiry < DateTime.Today)
                    {
                        <MudText Typo="Typo.body2">Expired</MudText>
                    }
                    else
                    {
                        <MudStack>
                            <MudText Typo="Typo.body2">
                                @context.Expiry.Date.ToString("d")
                            </MudText>
                            <MudText Typo="Typo.body2">
                                @if (context.Expiry == DateTime.Today)
                                {
                                    @("Today")
                                }
                                else
                                {
                                    @context.Expiry.Humanize()
                                }
                            </MudText>
                        </MudStack>
                    }
                </MudTooltip>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText>@ConstantString.NoRecords</MudText>
        </NoRecordsContent>
        <LoadingContent>
            <MudText>@ConstantString.Loading</MudText>
        </LoadingContent>
    </MudTable>
</MudContainer>
