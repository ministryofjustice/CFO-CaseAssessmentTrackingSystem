@page "/pages/qa/activities/qa2/"

@using Cfo.Cats.Application.Common.Validators
@using Cfo.Cats.Application.Features.Activities.Commands
@using Cfo.Cats.Application.SecurityConstants
@using Cfo.Cats.Domain.Common.Enums
@using Cfo.Cats.Server.UI.Pages.QA.Activities.Components

@inherits CatsComponentBase

@attribute [Authorize(Policy = SecurityPolicies.Qa2)]

<style>
    .document-container {
        width: 90%;
        height: calc(100vh - 350px);
        display: flex;
        justify-content: center;
        align-items: center;
    }

</style>

<ActivityQaExternalMessageWarning @ref="_warningMessage" />

<MudContainer Style="width: 100%; min-width: 480px;" MaxWidth="MaxWidth.ExtraLarge">
    <MudText Typo="Typo.h5" Class="mb-5">
        CFO Activity Queue Second Pass
    </MudText>

    @if (_activityQaDetailsDto is null)
    {
        <MudButton OnClick="@GetQueueItem" ButtonType="ButtonType.Button" StartIcon="@Icons.Material.Filled.QueuePlayNext"
        Variant="Variant.Filled" Color="Color.Primary">
            Get Next
        </MudButton>
    }
    else if(_activityQaDetailsDto.Status== ActivityStatus.SubmittedToAuthorityStatus)
    {

        @if (_queueEntry!.IsAccepted)
        {
            <MudAlert Severity="Severity.Warning">
                This entry has already been processed
            </MudAlert>
        }

        <MudGrid Style="height: 100vh; width: 100%;">
            <MudItem xs="4" Style="height: calc(100vh - 150px); width: 100%;">
                <ActivityQaDetails Activity="_activityQaDetailsDto" />
            </MudItem>

            <MudItem xs="8" Style="height: 100%; width: 100%;">
                <MudTabs>
                    <MudTabPanel Text="QA Notes">
                        <QaNotes ActivityId="@_activityQaDetailsDto.ActivityId" FirstPassUser="@_queueEntry.Qa1CompletedBy"/>
                    </MudTabPanel>

                    <MudTabPanel Text="Previous Activities" Style="min-width: 185px;" BadgeColor="Color.Info">
                        <PreviousActivitiesPanel ActivityId="@_activityQaDetailsDto.ActivityId" />
                    </MudTabPanel>

                    <MudTabPanel Text="Attachment" Style="min-width: 185px;" BadgeColor="Color.Info">                        
                        <AttachmentTabPanel ActivityQaDetailsDto="_activityQaDetailsDto" />
                    </MudTabPanel>
                    <MudTabPanel Text="Submission">
                        @if (_queueEntry.IsCompleted == false)
                        {
                            <MudForm Model="@Command" @ref="_form" Validation="@(Validator.ValidateValue(Command))">

                                <MudStack>
                                    <MudRadioGroup T="SubmitActivityQa2Response.Qa2Response?" @bind-Value="Command.Response" For="@(() => Command.Response)" @bind-Value:after="OnResponseChanged" Required="true">
                                        <MudRadio T="SubmitActivityQa2Response.Qa2Response?" Value="SubmitActivityQa2Response.Qa2Response.Accept" Color="Color.Primary">
                                            Accept
                                        </MudRadio>
                                        <MudRadio T="SubmitActivityQa2Response.Qa2Response?" Value="SubmitActivityQa2Response.Qa2Response.Return" Color="Color.Secondary">
                                            Return
                                        </MudRadio>
                                        <MudRadio T="SubmitActivityQa2Response.Qa2Response?" Value="SubmitActivityQa2Response.Qa2Response.Escalate" Color="Color.Secondary">
                                            Escalate
                                        </MudRadio>
                                    </MudRadioGroup>

                                    <!-- Internal Comment -->
                                    <MudPaper Elevation="3" Class="pa-2 ma-2">
                                        <MudAlert Severity="Severity.Info" Variant="Variant.Filled">
                                            This message will only be visible to CFO Staff
                                        </MudAlert>
                                        <MudTextField @bind-Value="Command.Message" Label="Internal Message" Lines="5" For="() => Command.Message" MaxLength="@ValidationConstants.NotesLength" Immediate="true" Counter="@ValidationConstants.NotesLength"/>
                                    </MudPaper>
                                                                    
                                    @if (Command.Response == SubmitActivityQa2Response.Qa2Response.Accept || Command.Response == SubmitActivityQa2Response.Qa2Response.Return)
                                    {      
                                        <!-- Feedback for QA Officer -->
                                        <MudPaper Elevation="3" Class="pa-2 ma-2">
                                            <MudAlert Severity="Severity.Success" Variant="Variant.Filled" Icon="@Icons.Material.Filled.Feedback">
                                                Optional anonymous internal feedback for @_queueEntry.Qa1CompletedBy
                                            </MudAlert>
                                            <MudTextField @bind-Value="Command.MessageToQa1" Label="@Command.GetMemberDescription(x => x.MessageToQa1)" Lines="5" For="() => Command.MessageToQa1" MaxLength="@ValidationConstants.NotesLength" Immediate="true" Counter="@ValidationConstants.NotesLength"/>
                                            <MudSelect @bind-Value="Command.ActivityFeedbackReason" 
                                                        For="() => Command.ActivityFeedbackReason"
                                                        Label="@Command.GetMemberDescription(x => x.ActivityFeedbackReason)">
                                                @foreach (var activityFeedbackReason in PicklistService.DataSource
                                                                .Where(c => c.Name == Picklist.QaFeedbackReason)
                                                                .OrderBy(c => c.Text))
                                                {
                                                    <MudSelectItem Value="@activityFeedbackReason.Value">@activityFeedbackReason.Text</MudSelectItem>
                                                }
                                            </MudSelect>
                                        </MudPaper>

                                        <!-- PQA Feedback -->
                                        <MudPaper Elevation="3" Class="pa-2 ma-2">
                                            <MudRadioGroup T="FeedbackType?" @bind-Value="Command.FeedbackType" For="@(() => Command.FeedbackType)">
                                                <MudRadio T="FeedbackType?" Value="FeedbackType.NotApplicable" Color="Color.Default" Disabled="@(Command.Response == SubmitActivityQa2Response.Qa2Response.Return)">
                                                    N/A
                                                </MudRadio>
                                                <MudRadio T="FeedbackType?" Value="FeedbackType.Advisory" Color="Color.Primary" Disabled="@(Command.Response == SubmitActivityQa2Response.Qa2Response.Return)">
                                                    Advisory
                                                </MudRadio>
                                                <MudRadio T="FeedbackType?" Value="FeedbackType.AcceptedByException" Color="Color.Secondary" Disabled="@(Command.Response == SubmitActivityQa2Response.Qa2Response.Return)">
                                                    Accepted By Exception
                                                </MudRadio>
                                                <MudRadio T="FeedbackType?" Value="FeedbackType.Returned" Color="Color.Secondary" Disabled="@(Command.Response == SubmitActivityQa2Response.Qa2Response.Accept)">
                                                    Returned
                                                </MudRadio>                                        
                                            </MudRadioGroup>

                                            @if (Command.Response == SubmitActivityQa2Response.Qa2Response.Return)
                                            {
                                                <MudSelect @bind-Value="Command.ReturnReason" 
                                                           For="() => Command.ReturnReason"
                                                           Label="Return Reason"
                                                           Required="true"
                                                           Class="mt-4">
                                                    @foreach (var returnReason in PicklistService.DataSource
                                                                    .Where(c => c.Name == Picklist.QaReturnReason)
                                                                    .OrderBy(c => c.Text))
                                                    {
                                                        <MudSelectItem Value="@returnReason.Value">@returnReason.Text</MudSelectItem>
                                                    }
                                                </MudSelect>
                                            }
                                        
                                            <MudAlert Severity="Severity.Warning" Variant="Variant.Filled">
                                                This comment will be visible to all users (including PQA)
                                            </MudAlert>
                                            
                                            <MudTextField @bind-Value="Command.MessageToProvider" Label="External Message" Lines="5" For="() => Command.MessageToProvider" MaxLength="@ValidationConstants.NotesLength" Immediate="true" Counter="@ValidationConstants.NotesLength" />
                                        
                                        </MudPaper>
                                    }
                               </MudStack>
 
                            </MudForm>

                            <MudContainer Class="d-flex px-0 pt-8">
                                <MudButton Color="Color.Primary" OnClick="@SubmitToQa" Variant="Variant.Filled">Submit</MudButton>
                            </MudContainer>                            
                            
                        }
                        else
                        {
                            <MudAlert Variant="Variant.Filled" Severity="Severity.Info">
                                This entry has already been processed
                            </MudAlert>
                        }
                    </MudTabPanel>
                </MudTabs>
            </MudItem>
        </MudGrid>
    }
    else 
    {
        <MudAlert Variant="Variant.Filled" Severity="Severity.Error">
            Something has gone wrong, cannot process an activity that is @_activityQaDetailsDto.Status.Name
        </MudAlert>
    }
</MudContainer>

@code {

    private RenderFragment RenderFailure(string title, IResult result) =>
        @<div>
            <h2>@title</h2>
            <ul>
                @foreach (var e in result.Errors)
                {
                    <li>@e</li>
                }
            </ul>
        </div>;
}