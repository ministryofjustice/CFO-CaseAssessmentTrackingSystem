@using Cfo.Cats.Application.SecurityConstants
@using Cfo.Cats.Server.UI.Pages.QA.Activities.Components

@page "/pages/qa/activities/activities"
@attribute [Authorize(Policy = SecurityPolicies.ServiceDeskManagement)]

<MudContainer Style="height: 100%; width: 100%; min-width: 480px" MaxWidth="MaxWidth.ExtraExtraLarge">
        <MudText Typo="Typo.h5" Class="mb-3">
            Activity Queues
        </MudText>
        <MudTabs Elevation="2" Border="false" ApplyEffectsToContainer="true" TabPanelsClass="pa-2" Color="Color.Info">
            <MudTabPanel Text="First Pass">
                <QA1List/>
            </MudTabPanel>
            <MudTabPanel Text="Second Pass">
                <QA2List/>
            </MudTabPanel>
            <MudTabPanel Text="Escalation">
                <EscalationList />
            </MudTabPanel>
        </MudTabs>
</MudContainer>
