@using Cfo.Cats.Application.Features.Participants.DTOs
@using Cfo.Cats.Domain.Common.Enums
@using Cfo.Cats.Server.UI.Components.Stepper
@using FluentValidation.Internal
@using Humanizer

@inherits CatsComponentBase
@implements IValidatorStrategy<RiskDto>

@if (Model is not null)
{

    if(ViewMode == RiskComponentViewMode.Stepper)
    {
        <CatsMudStep Title="Risk Overview">
            <MudGrid>
                @* Is Relevant to Custody/Community *@
                <MudItem xs="4">
                    Risk Details are relevant to
                </MudItem>
                <MudItem xs="8">
                    <div class="d-flex align-center gap-4">
                        <MudCheckBox ReadOnly="@(ReadOnly || Model.LocationType?.IsCustody == true)" @bind-Value="@Model.IsRelevantToCustody" Label="@Model.GetMemberDescription(x => x.IsRelevantToCustody)" />
                        @if (ReadOnly == false && Model.LocationType?.IsCustody == true)
                        {
                            <MudTooltip Text="The Risk in Custody section is mandatory because the selected location for this review is of type 'Custody'.">
                                <MudIconButton Icon="@Icons.Material.Filled.Info" Size="@Size.Small" Color="Color.Info" Class="mr-2" />
                            </MudTooltip>
                        }
                        <MudTextField ReadOnly Underline="false" For="@(() => Model.IsRelevantToCustody)" hidden />
                    </div>
                    <div class="d-flex align-center gap-4">
                        <MudCheckBox ReadOnly="@(ReadOnly || Model.LocationType?.IsCommunity == true)" @bind-Value="@Model.IsRelevantToCommunity" Label="@Model.GetMemberDescription(x => x.IsRelevantToCommunity)" />
                        @if (ReadOnly == false && Model.LocationType?.IsCommunity == true)
                        {
                            <MudTooltip Text="The Risk in Community section is mandatory because selected location for this review is of type 'Community'">
                                <MudIconButton Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Info" Class="mr-2" />
                            </MudTooltip>
                        }
                        <MudTextField ReadOnly Underline="false" For="@(() => Model.IsRelevantToCommunity)" hidden />
                        </div>
                </MudItem>

                @if (HasOptionSelected)
                {
                    <MudDivider Class="mt-6 mb-8"/>
                    <MudExpansionPanels MultiExpansion Elevation="@(ReadOnly ? 0 : 1)" Outlined="ReadOnly is false">
                        @if (Model.IsRelevantToCustody)
                        {
                            <MudExpansionPanel Text="Risks in Custody" Expanded HideIcon="ReadOnly">
                                <RiskDetail Model="Model.CustodyRiskDetail" />
                            </MudExpansionPanel>
                        }
                        @if (Model.IsRelevantToCommunity)
                        {
                            <MudExpansionPanel Text="Risks in Community" Expanded HideIcon="ReadOnly">
                                <RiskDetail Model="Model.CommunityRiskDetail" Community="true" />
                            </MudExpansionPanel>
                        }
                    </MudExpansionPanels>
                }
            </MudGrid>
        </CatsMudStep>
    }
    else 
    {
        <MudGrid>
            @* Is Relevant to Custody/Community *@
            <MudItem xs="4">
                Risk Details are relevant to
            </MudItem>
            <MudItem xs="8">
                <div class="d-flex align-center gap-4">
                    <MudCheckBox ReadOnly="@(ReadOnly || Model.LocationType?.IsCustody == true)" @bind-Value="@Model.IsRelevantToCustody" Label="@Model.GetMemberDescription(x => x.IsRelevantToCustody)" />
                    @if (ReadOnly == false && Model.LocationType?.IsCustody == true)
                    {
                        <MudTooltip Text="The Risk in Custody section is mandatory because the selected location for this review is of type 'Custody'.">
                            <MudIconButton Icon="@Icons.Material.Filled.Info" Size="@Size.Small" Color="Color.Info" Class="mr-2" />
                        </MudTooltip>
                    }
                    <MudTextField ReadOnly Underline="false" For="@(() => Model.IsRelevantToCustody)" hidden />
                </div>
                <div class="d-flex align-center gap-4">
                    <MudCheckBox ReadOnly="@(ReadOnly || Model.LocationType?.IsCommunity == true)" @bind-Value="@Model.IsRelevantToCommunity" Label="@Model.GetMemberDescription(x => x.IsRelevantToCommunity)" />
                    @if (ReadOnly == false && Model.LocationType?.IsCommunity == true)
                    {
                        <MudTooltip Text="The Risk in Community section is mandatory because selected location for this review is of type 'Community'">
                            <MudIconButton Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Info" Class="mr-2" />
                        </MudTooltip>
                    }
                    <MudTextField ReadOnly Underline="false" For="@(() => Model.IsRelevantToCommunity)" hidden />
                    </div>
            </MudItem>

            @if (HasOptionSelected)
            {
                <MudDivider Class="mt-6 mb-8"/>
                <MudExpansionPanels MultiExpansion Elevation="@(ReadOnly ? 0 : 1)" Outlined="ReadOnly is false">
                    @if (Model.IsRelevantToCustody)
                    {
                        <MudExpansionPanel Text="Risks in Custody" Expanded HideIcon="ReadOnly">
                            <RiskDetail Model="Model.CustodyRiskDetail" />
                        </MudExpansionPanel>
                    }
                    @if (Model.IsRelevantToCommunity)
                    {
                        <MudExpansionPanel Text="Risks in Community" Expanded HideIcon="ReadOnly">
                            <RiskDetail Model="Model.CommunityRiskDetail" Community="true" />
                        </MudExpansionPanel>
                    }
                </MudExpansionPanels>
            }
        </MudGrid>
    }

   
}