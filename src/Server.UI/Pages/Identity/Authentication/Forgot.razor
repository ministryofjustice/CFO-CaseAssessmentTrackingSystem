@page "/pages/authentication/forgot-password"

<PageTitle>@Title</PageTitle>

<MudText Typo="Typo.h2" Class="mb-2">
    Forgotten Password
</MudText>
<MudText Typo="Typo.subtitle1" GutterBottom="true">
    Need help accessing your account?
</MudText>
<MudText Typo="Typo.body1">
    If you've forgotten your password, please contact the CFO Service Desk. A member of the team will verify your details and assist with the password reset process.
</MudText>

@code {

    public const string PageUrl = "/pages/authentication/forgot-password";

    public string Title { get; } = "Forgot Password";

}