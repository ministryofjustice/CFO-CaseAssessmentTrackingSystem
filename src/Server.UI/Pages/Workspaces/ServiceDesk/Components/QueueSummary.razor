@using Cfo.Cats.Application.Features.QualityAssurance.DTOs

@inherits CatsComponent<ServiceDeskQueueSummaryDto>

@if (Loading)
{
    <MudLoading Text="Fetching queue summary..." />
}

@if (ErrorMessage is not null)
{
    <MudAlert Variant="Variant.Filled" Severity="Severity.Error">
        @ErrorMessage
    </MudAlert>
}

@if (!Loading && ErrorMessage is null)
{
    @if (ShowActivities)
    {
        <MudText Typo="Typo.h6" Class="pt-2 px-2">Activities</MudText>
        <MudList T="string" ReadOnly="false" Class="pa-2">
            @if (CanViewFirstPass)
            {
                <MudTooltip Text="Open next item">
                <MudListItem T="string" Icon="@Icons.Material.Filled.ListAlt" OnClick="@GrabActivityQa1">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Style="width:100%">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body1">First Pass</MudText>
                            <MudText Typo="Typo.h6" Color="@GetCountColor(_activityQa1Count)">@_activityQa1Count</MudText>
                        </MudStack>
                    </MudStack>
                </MudListItem>
                </MudTooltip>
            }

            @if (CanViewSecondPass)
            {
                <MudTooltip Text="Open next item">
                <MudListItem T="string" Icon="@Icons.Material.Filled.ListAlt" OnClick="@GrabActivityQa2">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Style="width:100%">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body1">Second Pass</MudText>
                            <MudText Typo="Typo.h6" Color="@GetCountColor(_activityQa2Count)">@_activityQa2Count</MudText>
                        </MudStack>
                    </MudStack>
                </MudListItem>
                </MudTooltip>
            }

            @if (CanViewEscalation)
            {
                <MudListItem T="string" Icon="@Icons.Material.Filled.ListAlt" Disabled>
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Style="width:100%">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body1">Escalation</MudText>
                            <MudText Typo="Typo.h6" Color="@GetCountColor(_activityEscalationCount)">@_activityEscalationCount</MudText>
                        </MudStack>
                    </MudStack>
                </MudListItem>
            }
        </MudList>
    }

    @if (ShowEnrolments)
    {
        <MudText Typo="Typo.h6" Class="pt-2 px-2">Enrolments</MudText>
        <MudList T="string" ReadOnly="false" Class="pa-2">
            @if (CanViewFirstPass)
            {
                <MudTooltip Text="Open next item">
                <MudListItem T="string" Icon="@Icons.Material.Filled.ListAlt" OnClick="@GrabEnrolmentQa1">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Style="width:100%">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body1">First Pass</MudText>
                            <MudText Typo="Typo.h6" Color="@GetCountColor(_enrolmentQa1Count)">@_enrolmentQa1Count</MudText>
                        </MudStack>
                    </MudStack>
                </MudListItem>
                </MudTooltip>
            }

            @if (CanViewSecondPass)
            {
                <MudTooltip Text="Open next item">
                <MudListItem T="string" Icon="@Icons.Material.Filled.ListAlt" OnClick="@GrabEnrolmentQa2">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Style="width:100%">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body1">Second Pass</MudText>
                            <MudText Typo="Typo.h6" Color="@GetCountColor(_enrolmentQa2Count)">@_enrolmentQa2Count</MudText>
                        </MudStack>
                    </MudStack>
                </MudListItem>
                </MudTooltip>
            }

            @if (CanViewEscalation)
            {
                <MudListItem T="string" Icon="@Icons.Material.Filled.ListAlt" Disabled>
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Style="width:100%">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body1">Escalation</MudText>
                            <MudText Typo="Typo.h6" Color="@GetCountColor(_enrolmentEscalationCount)">@_enrolmentEscalationCount</MudText>
                        </MudStack>
                    </MudStack>
                </MudListItem>
            }
        </MudList>
    }

}