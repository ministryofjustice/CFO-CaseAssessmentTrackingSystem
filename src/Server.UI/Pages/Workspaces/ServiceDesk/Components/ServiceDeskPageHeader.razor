@using Microsoft.AspNetCore.WebUtilities
@using Cfo.Cats.Server.UI.Pages.Workspaces.ServiceDesk.Services

<PageHeader Title="Service Desk"
            Items="@_breadcrumbs" />

@code
{
    private IReadOnlyList<BreadcrumbItem> _breadcrumbs = [];

    protected override void OnParametersSet()
    {
        _breadcrumbs = BuildBreadcrumbs();
    }

    private IReadOnlyList<BreadcrumbItem> BuildBreadcrumbs()
    {
        var home = ServiceDeskLinks.Home.AsMudBreadcrumb();

        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var homeUrl = ServiceDeskLinks.Home.Href;

        var segment = uri.AbsolutePath.StartsWith(homeUrl, StringComparison.OrdinalIgnoreCase)
            ? uri.AbsolutePath[homeUrl.Length..].Trim('/')
            : uri.AbsolutePath.Trim('/');

        return segment switch
        {
            "" => [home],
            "activities/queue" => [home, ServiceDeskLinks.ActivitiesQueue.AsMudBreadcrumb()],
            "activities/feedback" => [home, ServiceDeskLinks.ActivitiesFeedback.AsMudBreadcrumb()],
            "enrolments/queue" => [home, ServiceDeskLinks.EnrolmentsQueue.AsMudBreadcrumb()],
            "enrolments/feedback" => [home, ServiceDeskLinks.EnrolmentsFeedback.AsMudBreadcrumb()],
            "sync/syncinfo" => [home, ServiceDeskLinks.SyncInfo.AsMudBreadcrumb()],
            "qapots" => [home, ServiceDeskLinks.QaPots.AsMudBreadcrumb()],
            _ => BuildServiceDeskBreadcrumbs(home, segment, uri)
        };
    }

    private static IReadOnlyList<BreadcrumbItem> BuildServiceDeskBreadcrumbs(BreadcrumbItem home, string segment, Uri uri)
    {
        // For deeper pages, keep Service Desk as the root crumb and infer a middle
        // crumb so users can easily navigate back to the nearest main area.
        var middle = home;

        var normalizedSegment = segment.ToLowerInvariant();

        if (normalizedSegment.StartsWith("activities/", StringComparison.Ordinal))
        {
            middle = BuildProcessingBreadcrumb("Activity", "activities", normalizedSegment, uri);
        }
        else if (normalizedSegment.StartsWith("enrolments/", StringComparison.Ordinal))
        {
            middle = BuildProcessingBreadcrumb("Enrolment", "enrolments", normalizedSegment, uri);
        }

        if (QueryHelpers.ParseQuery(uri.Query).TryGetValue("from", out var from))
        {
            middle = from.ToString().ToLowerInvariant() switch
            {
                "activities-feedback" => ServiceDeskLinks.ActivitiesFeedback.AsMudBreadcrumb(),
                "enrolments-feedback" => ServiceDeskLinks.EnrolmentsFeedback.AsMudBreadcrumb(),
                "activities-item" => BuildItemBreadcrumbFromQuery("Activity", "activities", uri.Query),
                "enrolments-item" => BuildItemBreadcrumbFromQuery("Enrolment", "enrolments", uri.Query),
                _ => middle
            };
        }

        var currentTitle = normalizedSegment switch
        {
            var s when s.Contains("qa/activities/", StringComparison.Ordinal) => "Activity",
            var s when s.Contains("qa/enrolments/", StringComparison.Ordinal) => "Enrolment",
            _ => BuildFallbackTitle(segment)
        };

        return [home, middle, new BreadcrumbItem(currentTitle, href: null, disabled: true)];
    }

    private static BreadcrumbItem BuildProcessingBreadcrumb(string title, string queueType, string normalizedSegment, Uri uri)
    {
        if (normalizedSegment.StartsWith($"{queueType}/qa1", StringComparison.Ordinal))
        {
            return BuildQaBreadcrumb(title, queueType, "qa1", uri.Query);
        }

        if (normalizedSegment.StartsWith($"{queueType}/qa2", StringComparison.Ordinal))
        {
            return BuildQaBreadcrumb(title, queueType, "qa2", uri.Query);
        }

        if (normalizedSegment.StartsWith($"{queueType}/escalation/", StringComparison.Ordinal))
        {
            var escalationId = normalizedSegment.Split('/', StringSplitOptions.RemoveEmptyEntries).LastOrDefault();
            if (Guid.TryParse(escalationId, out var parsedEscalationId))
            {
                return new BreadcrumbItem(title, $"{ServiceDeskLinks.Home.Href}/{queueType}/escalation/{parsedEscalationId}");
            }
        }

        return new BreadcrumbItem(title, $"{ServiceDeskLinks.Home.Href}/{queueType}/qa1?action=next");
    }

    private static BreadcrumbItem BuildItemBreadcrumbFromQuery(string title, string queueType, string queryString)
    {
        var parsedQuery = QueryHelpers.ParseQuery(queryString);
        var stage = parsedQuery.TryGetValue("stage", out var stageValue)
            ? stageValue.ToString().ToLowerInvariant()
            : "qa1";

        return stage switch
        {
            "qa2" => BuildQaBreadcrumb(title, queueType, "qa2", queryString),
            "escalation" when parsedQuery.TryGetValue("id", out var escalationId) && Guid.TryParse(escalationId.ToString(), out var parsedEscalationId)
                => new BreadcrumbItem(title, $"{ServiceDeskLinks.Home.Href}/{queueType}/escalation/{parsedEscalationId}"),
            _ => BuildQaBreadcrumb(title, queueType, "qa1", queryString)
        };
    }

    private static BreadcrumbItem BuildQaBreadcrumb(string title, string queueType, string qaStage, string queryString)
    {
        var parsedQuery = QueryHelpers.ParseQuery(queryString);
        if (parsedQuery.TryGetValue("queueEntryId", out var queueEntryId)
            && Guid.TryParse(queueEntryId.ToString(), out var parsedQueueEntryId))
        {
            return new BreadcrumbItem(title, $"{ServiceDeskLinks.Home.Href}/{queueType}/{qaStage}?queueEntryId={parsedQueueEntryId}");
        }

        return new BreadcrumbItem(title, $"{ServiceDeskLinks.Home.Href}/{queueType}/{qaStage}");
    }

    private static string BuildFallbackTitle(string segment)
    {
        var parts = segment.Split('/', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 0)
        {
            return "Details";
        }

        var last = parts[^1];
        if (Guid.TryParse(last, out _) && parts.Length > 1)
        {
            last = parts[^2];
        }

        if (last.Equals("qa1", StringComparison.OrdinalIgnoreCase))
        {
            return "QA1";
        }

        if (last.Equals("qa2", StringComparison.OrdinalIgnoreCase))
        {
            return "QA2";
        }

        return char.ToUpperInvariant(last[0]) + last[1..];
    }
}
