@using Cfo.Cats.Application.SecurityConstants
@using Cfo.Cats.Server.UI.Pages.Workspaces.ServiceDesk.Components
@using Cfo.Cats.Server.UI.Pages.Workspaces.ServiceDesk.Pages.Activities.Components

@page "/pages/workspace/servicedesk/activities/queue"
@page "/pages/qa/activities/activities"
@attribute [Authorize(Policy = SecurityPolicies.Qa1)]

<ServiceDeskPageHeader />

<MudContainer Style="height: 100%; width: 100%; min-width: 480px" MaxWidth="MaxWidth.ExtraExtraLarge">
    <MudText Typo="Typo.h5" Class="mb-3">Activities Queue</MudText>
    <MudTabs @bind-ActivePanelIndex="_activePanelIndex" Elevation="2" Border="false" ApplyEffectsToContainer="true" TabPanelsClass="pa-2" Color="Color.Info">
        <MudTabPanel Text="First Pass">
            <QA1List />
        </MudTabPanel>

        <AuthorizeView Policy="@SecurityPolicies.ServiceDeskManagement">
            <MudTabPanel Text="Second Pass">
                <QA2List />
            </MudTabPanel>
            <MudTabPanel Text="Escalation">
                <EscalationList />
            </MudTabPanel>
        </AuthorizeView>
    </MudTabs>
</MudContainer>
