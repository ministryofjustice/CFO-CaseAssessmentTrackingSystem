@inherits CatsComponentBase

@if (_loading)
{
    <MudLoading Text="Fetching queue summary..." />
}
else
{
    @if (ShowActivities)
    {
        <MudText Typo="Typo.h6" Class="pt-2 px-2">Activities</MudText>
        <MudGrid Class="pa-2">
            @if (CanViewFirstPass)
            {
                <MudItem xs="12" md="4">
                    <MudCard Style="height:100%">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">First Pass</MudText>
                                <MudText Typo="Typo.caption">Activities in QA1 stage</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudText Typo="Typo.h3" Color="@GetCountColor(_activityQa1Count)">
                                @_activityQa1Count
                            </MudText>
                            <MudButton OnClick="@GrabActivityQa1"
                                       StartIcon="@Icons.Material.Filled.QueuePlayNext"
                                       Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Disabled="@_grabbing"
                                       Class="mt-4">
                                Get Next
                            </MudButton>
                            <MudButton OnClick="@(() => ViewQueue("Activities|First Pass"))"
                                       StartIcon="@Icons.Material.Filled.ViewList"
                                       Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Class="mt-4 ml-2">
                                View Queue
                            </MudButton>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }

            @if (CanViewSecondPass)
            {
                <MudItem xs="12" md="4">
                    <MudCard Style="height:100%">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">Second Pass</MudText>
                                <MudText Typo="Typo.caption">Activities in QA2 stage</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudText Typo="Typo.h3" Color="@GetCountColor(_activityQa2Count)">
                                @_activityQa2Count
                            </MudText>
                            <MudButton OnClick="@GrabActivityQa2"
                                       StartIcon="@Icons.Material.Filled.QueuePlayNext"
                                       Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Disabled="@_grabbing"
                                       Class="mt-4">
                                Get Next
                            </MudButton>
                            <MudButton OnClick="@(() => ViewQueue("Activities|Second Pass"))"
                                       StartIcon="@Icons.Material.Filled.ViewList"
                                       Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Class="mt-4 ml-2">
                                View Queue
                            </MudButton>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }

            @if (CanViewEscalation)
            {
                <MudItem xs="12" md="4">
                    <MudCard Style="height:100%">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">Escalation</MudText>
                                <MudText Typo="Typo.caption">Activities in escalation stage</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudText Typo="Typo.h3" Color="@GetCountColor(_activityEscalationCount)">
                                @_activityEscalationCount
                            </MudText>
                            <MudButton OnClick="@(() => ViewQueue("Activities|Escalation"))"
                                       StartIcon="@Icons.Material.Filled.ViewList"
                                       Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Class="mt-4">
                                View Queue
                            </MudButton>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
        
    @if (ShowEnrolments)
    {
        <MudText Typo="Typo.h6" Class="pt-2 px-2">Enrolments</MudText>
        <MudGrid Class="pa-2">
            @if (CanViewFirstPass)
            {
                <MudItem xs="12" md="4">
                    <MudCard Style="height:100%">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">First Pass</MudText>
                                <MudText Typo="Typo.caption">Cases currently in QA1 stage</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudText Typo="Typo.h3" Color="@GetCountColor(_enrolmentQa1Count)">
                                @_enrolmentQa1Count
                            </MudText>
                            <MudButton OnClick="@GrabEnrolmentQa1"
                                       StartIcon="@Icons.Material.Filled.QueuePlayNext"
                                       Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Disabled="@_grabbing"
                                       Class="mt-4">
                                Get Next
                            </MudButton>
                            <MudButton OnClick="@(() => ViewQueue("Enrolments|First Pass"))"
                                       StartIcon="@Icons.Material.Filled.ViewList"
                                       Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Class="mt-4 ml-2">
                                View Queue
                            </MudButton>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }

            @if (CanViewSecondPass)
            {
                <MudItem xs="12" md="4">
                    <MudCard Style="height:100%">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">Second Pass</MudText>
                                <MudText Typo="Typo.caption">Cases currently in QA2 stage</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudText Typo="Typo.h3" Color="@GetCountColor(_enrolmentQa2Count)">
                                @_enrolmentQa2Count
                            </MudText>
                            <MudButton OnClick="@GrabEnrolmentQa2"
                                       StartIcon="@Icons.Material.Filled.QueuePlayNext"
                                       Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Disabled="@_grabbing"
                                       Class="mt-4">
                                Get Next
                            </MudButton>
                            <MudButton OnClick="@(() => ViewQueue("Enrolments|Second Pass"))"
                                       StartIcon="@Icons.Material.Filled.ViewList"
                                       Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Class="mt-4 ml-2">
                                View Queue
                            </MudButton>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }

            @if (CanViewEscalation)
            {
                <MudItem xs="12" md="4">
                    <MudCard Style="height:100%">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">Escalation</MudText>
                                <MudText Typo="Typo.caption">Cases currently in escalation stage</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudText Typo="Typo.h3" Color="@GetCountColor(_enrolmentEscalationCount)">
                                @_enrolmentEscalationCount
                            </MudText>
                            <MudButton OnClick="@(() => ViewQueue("Enrolments|Escalation"))"
                                       StartIcon="@Icons.Material.Filled.ViewList"
                                       Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Class="mt-4">
                                View Queue
                            </MudButton>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }

}