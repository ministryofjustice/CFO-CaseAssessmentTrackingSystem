@page "/pages/workspace/performance"
@using Cfo.Cats.Server.UI.Pages.Workspaces.Performance.Components
@using Cfo.Cats.Server.UI.Pages.Workspaces.Performance.Services


<PerformancePageHeader />

<MudGrid>
    <MudItem xs="12" md="6" lg="4">

    </MudItem>
    <MudItem xs="12" md="6" lg="4">
        <MudText Typo="Typo.h3">
            Performance Links
        </MudText>
        <MudStack Spacing="2" Class="mt-2" AlignItems="AlignItems.Stretch">
            @if (_allowOutcomeQualityDipChecks)
            {
                <MudStack Spacing="0">
                    <MudLink Href="@PerformanceLinks.OutcomeQualityDipSamples.Url" aria-describedby="OutcomeQualityLink">
                        @PerformanceLinks.OutcomeQualityDipSamples.Title
                    </MudLink>
                    <MudText id="OutcomeQualityLink" Typo="Typo.caption">
                        Review and assess outcome quality dip samples.
                    </MudText>
                </MudStack>

                <MudStack Spacing="0">
                    <MudLink Href="@PerformanceLinks.ArchivedCaseBehaviour.Url" aria-describedby="ArchivedCaseBehaviourLink">
                        @PerformanceLinks.ArchivedCaseBehaviour.Title
                    </MudLink>
                    <MudText id="ArchivedCaseBehaviourLink" Typo="Typo.caption">
                        View cases moving into and out of archiving.
                    </MudText>         
                </MudStack>

            }            
        </MudStack>
    </MudItem>
</MudGrid>