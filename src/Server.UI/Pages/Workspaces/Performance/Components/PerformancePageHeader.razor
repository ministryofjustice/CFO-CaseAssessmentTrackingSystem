@using Cfo.Cats.Server.UI.Pages.Workspaces.Performance.Services

<PageHeader Title="Performance Management"
            Items="@_breadcrumbs" />

@code
{
    // Optional friendly label for the dip-sample crumb. The sample's display name
    // ("{ContractName} ({Period})") is loaded from server data, so pages that have it
    // supply it here; the rest of the trail is derived from the current URL.
    [Parameter]
    public string? SampleLabel { get; set; }

    private IReadOnlyList<BreadcrumbItem> _breadcrumbs = [];

    private static class RouteSegments
    {
        public const string OutcomeQualityDipSampling = "outcome-quality-dip-sampling";
        public const string ArchivedCaseBehaviour = "archived-case-behaviour";
        public const string QaPots = "qapots";
    }
    
    protected override void OnParametersSet()
    {
        _breadcrumbs = BuildBreadcrumbs();
    }

    private IReadOnlyList<BreadcrumbItem> BuildBreadcrumbs()
    {
        var home = PerformanceLinks.Home.AsMudBreadcrumb();

        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var homeUrl = PerformanceLinks.Home.Href;

        var relativePath = uri.AbsolutePath.Length > homeUrl.Length
            ? uri.AbsolutePath[homeUrl.Length..].Trim('/')
            : string.Empty;

        var segments = relativePath.Split('/', StringSplitOptions.RemoveEmptyEntries);

        if (segments.Length == 0)
        {
            return [home];
        }

        List<BreadcrumbItem> crumbs = [
            home
        ];

        if(segments[0] == RouteSegments.OutcomeQualityDipSampling)
        {
            crumbs.Add(PerformanceLinks.OutcomeQualityDipSamples.AsMudBreadcrumb());
            
            // /outcome-quality-dip-sampling/{sampleId}
            if (segments.Length >= 2 && Guid.TryParse(segments[1], out var sampleId))
            {
                var sample = PerformanceLinks.OutcomeQualityDipSample(sampleId);
                var sampleTitle = string.IsNullOrWhiteSpace(SampleLabel) ? sample.Title : SampleLabel;
                crumbs.Add(new BreadcrumbItem(sampleTitle, sample.Href));

                // /outcome-quality-dip-sampling/{sampleId}/{participantId}
                if (segments.Length >= 3)
                {
                    crumbs.Add(PerformanceLinks.OutcomeQualityDipSampleParticipant(sampleId, segments[2]).AsMudBreadcrumb());
                }
            }
        }
        else if (segments[0] == RouteSegments.ArchivedCaseBehaviour)
        {
            crumbs.Add(PerformanceLinks.ArchivedCaseBehaviour.AsMudBreadcrumb());
        }
        else if (segments[0] == RouteSegments.QaPots)
        {
            crumbs.Add(PerformanceLinks.QaPots.AsMudBreadcrumb());
        }

        return crumbs;
    }
}
