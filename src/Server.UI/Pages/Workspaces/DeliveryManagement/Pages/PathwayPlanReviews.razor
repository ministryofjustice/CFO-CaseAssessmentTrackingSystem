@page "/pages/workspace/deliverymanagement/pathway-plan-reviews"
@inherits ProviderDashboardBase
@attribute [Authorize(Policy = SecurityPolicies.AuthorizedUser)]

@using Cfo.Cats.Server.UI.Components.Dashboard
@using Cfo.Cats.Server.UI.Pages.Workspaces.DeliveryManagement.Components

<DeliveryManagementPageHeader />

<MudStack Row="true" Class="my-4" Justify="Justify.FlexEnd" AlignItems="AlignItems.Center">
    <MudSwitch Label="Visual Mode" Color="Color.Info" Value="VisualMode" ValueChanged="OnVisualModeChanged" T="bool" />
    <MudSpacer />
    @if (CanFilter)
    {
        <ProviderDashboardFilter CurrentUser="CurrentUser"
                                 SelectedTenantId="@SelectedTenantId"
                                 SelectedUserId="@SelectedUserId"
                                 TenantSelected="OnTenantSelectedWithSave"
                                 UserSelected="OnUserSelectedWithSave"
                                 ClearRequested="OnClearFilterWithSave" />
    }
</MudStack>

<PathwayPlanReviewDashboardComponent UserId="@EffectiveUserId"
                                    TenantId="@EffectiveTenantId"
                                    @key="@SelectionKey"
                                    VisualMode="@VisualMode"
                                    ShowOverdueOnly="@_showOverdueOnly"
                                    ShowOverdueOnlyChanged="OnShowOverdueOnlyChanged" />
