@using Cfo.Cats.Server.UI.Pages.Workspaces.Administration.Services

<PageHeader Title="Administration" 
            Items="@_breadcrumbs" />

@code
{
    private IReadOnlyList<BreadcrumbItem> _breadcrumbs = [];

    protected override void OnParametersSet()
    {
        _breadcrumbs = BuildBreadcrumbs();
    }

    private IReadOnlyList<BreadcrumbItem> BuildBreadcrumbs()
    {
        var home = AdministrationLinks.Home.AsMudBreadcrumb();

        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var homeUrl = AdministrationLinks.Home.Href;

        var segment = uri.AbsolutePath.Length > homeUrl.Length
            ? uri.AbsolutePath[homeUrl.Length..].Trim('/').ToLower()
            : string.Empty;

        return segment switch
        {
            "" => [home],
            "jobs" => [home, AdministrationLinks.Jobs.AsMudBreadcrumb()],
            "cachemanagement" => [home, AdministrationLinks.CacheManagement.AsMudBreadcrumb()],
            "audittrails" => [home, AdministrationLinks.AuditTrails.AsMudBreadcrumb()],
            "outbox" => [home, AdministrationLinks.Outbox.AsMudBreadcrumb()],
            "picklist" => [home, AdministrationLinks.PickList.AsMudBreadcrumb()],
            "labels" => [home, AdministrationLinks.Labels.AsMudBreadcrumb()],
            "initiatives" => [home, AdministrationLinks.Initiatives.AsMudBreadcrumb()],
            "tenants" => [home, AdministrationLinks.Tenants.AsMudBreadcrumb()],
            "users/users" => [home, AdministrationLinks.Users.AsMudBreadcrumb()],
            "users/useraudit" => [home, AdministrationLinks.UserAudit.AsMudBreadcrumb()],
            _ => [home]
        };
    }
}
