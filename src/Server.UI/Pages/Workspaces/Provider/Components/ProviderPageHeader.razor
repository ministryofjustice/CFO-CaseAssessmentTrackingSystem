@using Cfo.Cats.Server.UI.Pages.Workspaces.Provider.Services

<PageHeader Title="Provider" 
            Items="@_breadcrumbs" />

@code
{
    private IReadOnlyList<BreadcrumbItem> _breadcrumbs = [];

    protected override void OnParametersSet()
    {
        _breadcrumbs = BuildBreadcrumbs();
    }

    private IReadOnlyList<BreadcrumbItem> BuildBreadcrumbs()
    {
        var home = ProviderLinks.Home.AsMudBreadcrumb();

        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var homeUrl = ProviderLinks.Home.Href;

        var segment = uri.AbsolutePath.Length > homeUrl.Length
            ? uri.AbsolutePath[homeUrl.Length..].Trim('/')
            : string.Empty;

        return segment switch
        {
            "" => [home],
            "case-workload" => [home, ProviderLinks.CaseWorkload.AsMudBreadcrumb()],
            "case-management" => [home, ProviderLinks.CaseManagement.AsMudBreadcrumb()],
            "performance" => [home, ProviderLinks.Performance.AsMudBreadcrumb()],
            "cumulatives" => [home, ProviderLinks.Cumulatives.AsMudBreadcrumb()],
            "enrolments/pqa" => [home, ProviderLinks.EnrolmentsPqa.AsMudBreadcrumb()],
            "activities/pqa" => [home, ProviderLinks.ActivitiesPqa.AsMudBreadcrumb()],
            _ when segment.StartsWith("enrolments/pqa/", StringComparison.Ordinal) =>
                [home, ProviderLinks.EnrolmentsPqa.AsMudBreadcrumb(), new BreadcrumbItem("Enrolment", href: null, disabled: true)],
            _ when segment.StartsWith("activities/pqa/", StringComparison.Ordinal) =>
                [home, ProviderLinks.ActivitiesPqa.AsMudBreadcrumb(), new BreadcrumbItem("Activity", href: null, disabled: true)],
            "payments" => [home, ProviderLinks.Payments.AsMudBreadcrumb()],
            _ => throw new Exception()
        };
    }

}
