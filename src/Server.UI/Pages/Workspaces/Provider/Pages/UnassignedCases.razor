@page "/pages/workspace/provider/unassigned-cases"
@using Cfo.Cats.Application.SecurityConstants
@using Cfo.Cats.Server.UI.Components.Dashboard
@using Cfo.Cats.Server.UI.Pages.Workspaces.Provider.Components

@attribute [Authorize(Policy = SecurityPolicies.UserHasAdditionalRoles)]

@inherits ProviderDashboardBase

<ProviderPageHeader />

<MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Class="mb-4">
    This page is still under development and may produce inaccurate results.
</MudAlert>

<MudStack Row="true" Class="my-4" Justify="Justify.FlexEnd" AlignItems="AlignItems.Center">
    <MudSwitch Label="Visual Mode" Color="Color.Info" @bind-Value="VisualMode" T="bool" />
    <MudSpacer />
    @if (CanFilter)
    {
        <ProviderDashboardFilter CurrentUser="CurrentUser"
                                 SelectedTenantId="@SelectedTenantId"
                                 SelectedUserId="@SelectedUserId"
                                 TenantSelected="OnTenantSelected"
                                 UserSelected="OnUserSelected"
                                 ClearRequested="OnClearFilter" />
    }
</MudStack>

@if (IsTenantLevel)
{
    <UnassignedCasesDashboardComponent TenantId="@EffectiveTenantId" @key="@SelectionKey" VisualMode="@VisualMode" />
}
else
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
        Unassigned cases are only available at tenant level. Clear user filters or select a tenant.
    </MudAlert>
}
