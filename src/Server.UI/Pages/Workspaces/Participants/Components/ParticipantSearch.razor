@inherits CatsComponent<List<Cfo.Cats.Application.Features.Participants.DTOs.ParticipantSearchResultDto>>

<MudPaper Class="pa-4 mb-4" Elevation="2">
    <MudStack Spacing="2">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudText Typo="Typo.h6">Search For A Participant</MudText>
            <MudTextField T="string"
                          @bind-Value="_searchTerm"
                          Immediate="true"
                          Placeholder="Search by name, ID, or identifier"
                          OnKeyDown="@OnKeyUp"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Adornment="Adornment.End"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Class="flex-grow-1" />
        </MudStack>

        @if (Loading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }

        @if (ErrorMessage is not null)
        {
            <MudAlert Variant="Variant.Filled"
                      Severity="Severity.Error"
                      Dense="true">
                @ErrorMessage
            </MudAlert>
        }
    </MudStack>
</MudPaper>