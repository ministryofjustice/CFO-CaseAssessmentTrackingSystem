@using Microsoft.AspNetCore.WebUtilities
@using Cfo.Cats.Server.UI.Pages.Workspaces.Participants.Services
@using Cfo.Cats.Server.UI.Pages.Workspaces.ServiceDesk.Services

<PageHeader Title="Participants" 
            Items="@_breadcrumbs" />

@code
{
    private IReadOnlyList<BreadcrumbItem> _breadcrumbs = [];

    protected override void OnParametersSet()
    {
        _breadcrumbs = BuildBreadcrumbs();
    }

    private IReadOnlyList<BreadcrumbItem> BuildBreadcrumbs()
    {
        var home = ParticipantLinks.Home.AsMudBreadcrumb();

        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var homeUrl = ParticipantLinks.Home.Href;

        var segment = uri.AbsolutePath.Length > homeUrl.Length
            ? uri.AbsolutePath[homeUrl.Length..].Trim('/')
            : string.Empty;

        return segment switch
        {
            "" => [home],
            "all" => [home, ParticipantLinks.All.AsMudBreadcrumb()],
            "activities" => [home, ParticipantLinks.AllActivities.AsMudBreadcrumb()],
            "transfers" => [home, ParticipantLinks.Transfers.AsMudBreadcrumb()],
            "pre-release-inventory" => [home, ParticipantLinks.AllPris.AsMudBreadcrumb()],
            "moved" => [home, ParticipantLinks.MovedParticipants.AsMudBreadcrumb()],
            _ => BuildParticipantBreadcrumbs(home, segment, uri)
        };
    }

    private static IReadOnlyList<BreadcrumbItem> BuildParticipantBreadcrumbs(BreadcrumbItem home, string id, Uri uri)
    {
        var participant = ParticipantLinks.Participant(id).AsMudBreadcrumb();
        var parsedQuery = QueryHelpers.ParseQuery(uri.Query);

        if (parsedQuery.TryGetValue("from", out var from))
        {
            return from.ToString().ToLowerInvariant() switch
            {
                "activities" => [home, ParticipantLinks.AllActivities.AsMudBreadcrumb(), participant],
                "activities-queue" => [ServiceDeskLinks.Home.AsMudBreadcrumb(), ServiceDeskLinks.ActivitiesQueue.AsMudBreadcrumb(), participant],
                "enrolments-queue" => [ServiceDeskLinks.Home.AsMudBreadcrumb(), ServiceDeskLinks.EnrolmentsQueue.AsMudBreadcrumb(), participant],
                "servicedesk" => [ServiceDeskLinks.Home.AsMudBreadcrumb(), ServiceDeskLinks.ActivitiesQueue.AsMudBreadcrumb(), participant],
                _ => [home, ParticipantLinks.All.AsMudBreadcrumb(), participant]
            };
        }

        return [home, ParticipantLinks.All.AsMudBreadcrumb(), participant];
    }

}
