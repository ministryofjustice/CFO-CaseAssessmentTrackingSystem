@page "/pages/workspace/participants/all"

@using Cfo.Cats.Application.Common.Interfaces.Locations
@using Cfo.Cats.Application.Features.Labels.DTOs
@using Cfo.Cats.Application.Features.Labels.Queries
@using Cfo.Cats.Application.Features.Locations.DTOs
@using Cfo.Cats.Application.Features.Participants.DTOs
@using Cfo.Cats.Application.Features.Participants.Queries
@using Cfo.Cats.Domain.Common.Enums
@using Cfo.Cats.Server.UI.Pages.Analytics
@using Cfo.Cats.Server.UI.Pages.Participants.Components
@using Cfo.Cats.Server.UI.Pages.Workspaces.Participants.Components
@using Cfo.Cats.Application.Features.Participants.Specifications
@using Cfo.Cats.Application.SecurityConstants
@using Cfo.Cats.Server.UI.Components.Labels
@using Cfo.Cats.Server.UI.Components.Locations

@inject IStringLocalizer<Participants> L

@inherits OwningComponentBase<IMediator>

@attribute [Authorize(Policy = SecurityPolicies.AuthorizedUser)]

    <ParticipantsPageHeader />

    <MudStack>
        <!-- Header/Filter row -->
        <MudStack Row="true" Justify="Justify.FlexEnd">
            <MudMenu Label="@($"Filters: {GetCurrentFilterLabel()}")" EndIcon="@Icons.Material.Filled.KeyboardArrowDown">
                <MudMenuItem OnClick="@(() => ClearQuickFilter())">All</MudMenuItem>
                <MudMenuItem OnClick="@(() => ApplyMyParticipantsFilter())">My Participants</MudMenuItem>
                <MudMenuItem OnClick="@(() => ApplyOverdueRiskFilter())">Overdue risk</MudMenuItem>
                <MudMenuItem OnClick="@(() => RecentlyAssignedFilterChanged(RecentParticipantFilter.AssignedLast10Days))">Assigned (Last 10 Days)</MudMenuItem>
                <MudMenuItem OnClick="@(() => RecentlyAssignedFilterChanged(RecentParticipantFilter.AssignedLast30Days))">Assigned (Last 30 Days)</MudMenuItem>
                <MudMenuItem OnClick="@(() => RecentlyVisitedFilterChanged())">Visited (Last 7 Days)</MudMenuItem>

            </MudMenu>
            <MudTextField T="string" Value="@Query.Keyword" Placeholder="@ConstantString.Search"
                          ValueChanged="@(OnSearch)" Clearable="true" ShrinkLabel="true"
                          AdornmentIcon="@Icons.Material.Filled.Search" Adornment="Adornment.Start"
                          AdornmentColor="Color.Secondary">
            </MudTextField>
            <MudSpacer />
            @if (_canReassign)
            {
                <MudButton Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.AssignmentInd" OnClick="ReassignSelectedItems"
                           Disabled="@(!_selectedParticipantIds.Any())">
                    Reassign Selected (@_selectedParticipantIds.Count)
                </MudButton>
                <MudButton Color="Color.Default" Variant="Variant.Outlined" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Deselect" OnClick="ClearSelectedParticipants"
                           Disabled="@(!_selectedParticipantIds.Any())">
                    Clear Selection
                </MudButton>
            }
            <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Info"
                       StartIcon="@Icons.Material.Filled.Refresh" OnClick="OnRefreshClicked">
                @ConstantString.Refresh
            </MudButton>
            <MudLoadingButton Color="Color.Secondary" Variant="Variant.Filled" Loading="_downloading" OnClick="OnExport"
                              StartIcon="@Icons.Material.Filled.CloudDownload" Size="Size.Small">
                @ConstantString.Export
            </MudLoadingButton>
            <MudButton Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.PersonAdd" OnClick="OnEnrol">
                Enrol
            </MudButton>
        </MudStack>

        <!-- Additional filters row -->
        <MudStack Row="true" Class="pt-4" Justify="Justify.FlexEnd" AlignItems="AlignItems.Center">

            <MudPagination 
                Selected="Query.PageNumber"
                Count="@_totalPages"
                MiddleCount="2"
                BoundaryCount="1"
                SelectedChanged="PageChanged"
                Size="Size.Small">
            </MudPagination>

            <MudText>
                @_totalItems @(Query.GroupBy == ParticipantGroupBy.None ? "records" : $"{Query.GroupBy.GetDescription().ToLower()} groups")
            </MudText>

            @if (_canReassign)
            {
                <MudText>
                    @_selectedParticipantIds.Count selected
                </MudText>
            }

            <!-- Tabular Switch (disabled while grouping, which uses card panels) -->
            <MudSwitch Label="Tabular" Value="@Tabular" Color="Color.Info" ValueChanged="@TabularChanged" T="bool?"
                       Disabled="@(Query.GroupBy != ParticipantGroupBy.None)" />

            <MudSpacer />

         

            <!-- Enrolment Status -->
            <MudMenu Size="Size.Small" Label="@Query.ListView.GetDescription()" EndIcon="@Icons.Material.Filled.KeyboardArrowDown">
                <MudMenuItem Label="Default" OnClick="@(() => ListViewChanged(ParticipantListView.Default))" />
                <MudMenuItem Label="Identified" OnClick="@(() => ListViewChanged(ParticipantListView.Identified))" />
                <MudMenuItem Label="Enrolling" OnClick="@(() => ListViewChanged(ParticipantListView.Enrolling))" />
                <MudMenuItem Label="PQA" OnClick="@(() => ListViewChanged(ParticipantListView.SubmittedToProvider))" />
                <MudMenuItem Label="CFO QA" OnClick="@(() => ListViewChanged(ParticipantListView.SubmittedToQa))" />
                <MudMenuItem Label="Any QA" OnClick="@(() => ListViewChanged(ParticipantListView.SubmittedToAny))" />
                <MudMenuItem Label="Approved" OnClick="@(() => ListViewChanged(ParticipantListView.Approved))" />
                <MudMenuItem Label="Dormant" OnClick="@(() => ListViewChanged(ParticipantListView.Dormant))" />
                <MudMenuItem Label="Archived" OnClick="@(() => ListViewChanged(ParticipantListView.Archived))" />
                <MudMenuItem Label="All" OnClick="@(() => ListViewChanged(ParticipantListView.All))" />
            </MudMenu>
             <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="ShowAssigneeDialog" EndIcon="@Icons.Material.Filled.KeyboardArrowDown">
                @if(string.IsNullOrEmpty(Query.OwnerId))
                {
                    @("All Assignees")
                }
                else
                {
                    @_users[Query.OwnerId]
                }
            </MudButton>
            <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="ShowTenantDialog" EndIcon="@Icons.Material.Filled.KeyboardArrowDown">
                @if(string.IsNullOrEmpty(Query.TenantId))
                {
                    @("All Tenants")
                }
                else
                {
                    @_tenants[Query.TenantId]
                }
            </MudButton>
            <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="ShowSelectLocationDialog" EndIcon="@Icons.Material.Filled.KeyboardArrowDown">
                @if(Query.Locations is [])
                {
                    @("All Locations")
                }
                else
                {
                    @_locations[Query.Locations[0]]
                }
            </MudButton>

            <MudMenu Size="Size.Small" Label="@(Query.Label is null ? "All Labels" : _labels[Query.Label!.Value].Name)" EndIcon="@Icons.Material.Filled.KeyboardArrowDown">
                <MudMenuItem Label="All" OnClick="@(() => LabelsValueChanged(null))" />
                @foreach(var l in _labels.Values.OrderBy(l => l.Name))
                {
                    <MudMenuItem Label="@l.Name" Icon="@l.AppIcon.AsMudIcon()" IconColor="@l.Colour.AsMudColour()" OnClick="@(() => LabelsValueChanged(l))"></MudMenuItem>
                }
            </MudMenu>

            <MudMenu Size="Size.Small" Label="Sort By" EndIcon="@Icons.Material.Filled.KeyboardArrowDown">
                <MudMenuItem Label="Id" OnClick="@(() => SortBy("Id"))"/>
                <MudMenuItem Label="First Name" OnClick="@(() => SortBy("FirstName"))"/>
                <MudMenuItem Label="Last Name" OnClick="@(() => SortBy("LastName"))"></MudMenuItem>
                <MudMenuItem Label="Assignee" OnClick="@(() => SortBy("Owner"))"/>
                <MudMenuItem Label="Tenant" OnClick="@(() => SortBy("Tenant"))"/>
                <MudMenuItem Label="Risk Due" OnClick="@(() => SortBy("RiskDue"))"/>
                @if (Query.RecentAction == RecentParticipantFilter.AssignedLast10Days || Query.RecentAction == RecentParticipantFilter.AssignedLast30Days)
                {
                    <MudMenuItem Label="Assigned On" OnClick="@(() => SortBy("AssignedOn"))"/>
                }
                @if (Query.RecentAction == RecentParticipantFilter.VisitedLast7Days)
                {
                    <MudMenuItem Label="Accessed On" OnClick="@(() => SortBy("AccessedOn"))"/>
                }
                <MudMenuItem Label="Current Location" OnClick="@(() => SortBy("CurrentLocation"))"/>
                <MudMenuItem Label="Enrolment Location" OnClick="@(() => SortBy("EnrolmentLocation"))"/>
                <MudMenuItem Label="Enrolment Status" OnClick="@(() => SortBy("EnrolmentStatus"))"/>
            </MudMenu>
            <MudMenu Size="Size.Small" Label="@($"Group by: {Query.GroupBy.GetDescription()}")" EndIcon="@Icons.Material.Filled.KeyboardArrowDown">
                <MudMenuItem Label="None" OnClick="@(() => GroupByChanged(ParticipantGroupBy.None))" />
                <MudMenuItem Label="Assignee" OnClick="@(() => GroupByChanged(ParticipantGroupBy.Assignee))" />
                <MudMenuItem Label="Tenant" OnClick="@(() => GroupByChanged(ParticipantGroupBy.Tenant))" />
            </MudMenu>
            <MudTooltip Text="Clear search parameters">
                <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Clear" OnClick="@(() => ClearSearch())" />
            </MudTooltip>
        </MudStack>
    </MudStack>

    @if(_groups is { Length: > 0 })
    {
        <ParticipantGroups Groups="_groups"
                           Filter="Query"
                           CanReassign="_canReassign"
                           RowsPerGroup="DefaultPageSize"
                           @bind-SelectedIds="_selectedParticipantIds" />
    }
    else
    {
        if (_data is { Length: > 0 })
        {
            <ParticipantResultsView Items="_data"
                                    Tabular="Tabular"
                                    CanReassign="_canReassign"
                                    RecentAction="Query.RecentAction"
                                    @bind-SelectedIds="_selectedParticipantIds" />
        }
        else
        {
            <MudAlert Severity="Severity.Info" Class="mt-4">No participants match the current filters.</MudAlert>
        }
    }
