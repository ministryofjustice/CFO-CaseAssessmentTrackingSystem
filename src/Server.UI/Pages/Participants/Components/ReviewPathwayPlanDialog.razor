@using Cfo.Cats.Application.Common.Validators
@using Cfo.Cats.Application.Features.PathwayPlans.Commands
@using Cfo.Cats.Domain.Common.Enums
@using Cfo.Cats.Server.UI.Components.Locations

@inject ICurrentUserService CurrentUser;
@inject IValidationService Validator

@inherits CatsComponentBase

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" Model="Model" Validation="@(Validator.ValidateValue(Model))">
            <MudSelect @bind-Value="Model.ReviewReason"
                       Label="@Model.GetMemberDescription(x => x.ReviewReason)"
                       For="@(() => Model.ReviewReason)">
               @foreach (var item in PathwayPlanReviewReason.OrderedList)
               {
                   <MudSelectItem T="PathwayPlanReviewReason" Value="@item">@item.Name</MudSelectItem>
               }
            </MudSelect>

            <MudTextField @bind-Value="Model.Review"
            Label="@Model.GetMemberDescription(x => x.Review)"
            For="@(() => Model.Review)"
            Required="true"
            Immediate="true"
            RequiredError="Review is required!"
            Lines="5"
            MaxLength=@ValidationConstants.NotesLength
            Counter=@ValidationConstants.NotesLength
            Class="mt-4" 
            />
       
             <MudDatePicker Label="@Model.GetMemberDescription(x => x.ReviewDate)"
                               @bind-Date="Model.ReviewDate"
                               For="(() => Model.ReviewDate)"
                               ImmediateText="true" Editable="false" MaxDate="DateTime.Today.Date" MinDate="DateTime.Today.AddMonths(-3)" PickerVariant="PickerVariant.Dialog" />
            
            <LocationSelectComponent
                TenantId="@(CurrentUser.TenantId!)"
                Label="@Model.GetMemberDescription(x => x.Location)"
                @bind-Value="Model.Location"
                For="() => Model.Location"/>

        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Secondary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Cancel" OnClick="@Cancel">@ConstantString.Cancel</MudButton>
        <MudLoadingButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Save" Loading="_saving" OnClick="@Submit">@ConstantString.Save</MudLoadingButton>
    </DialogActions>
</MudDialog>

