<MudTooltip Text="@Description">
    @if (Icon.AsMudIcon() is string icon)
    {
        <MudChip 
            T="string"        
            Variant="Variant.AsMudVariant()"       
            Color="Colour.AsMudColour()"        
            Size="Size.Small" 
            Icon="@icon"
            OnClose="OnClose"
            Disabled="Disabled">
            @Label
        </MudChip>
    }
    else
    {
        <MudChip 
            T="string" 
            Variant="Variant.AsMudVariant()" 
            Color="Colour.AsMudColour()" 
            Size="Size.Small"
            OnClose="OnClose"
            Disabled="Disabled">
            @Label
        </MudChip>
    }
</MudTooltip>