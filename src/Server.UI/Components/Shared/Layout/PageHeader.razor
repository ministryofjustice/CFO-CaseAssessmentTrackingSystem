

<MudStack>
    <MudStack Row="true">
        <MudIcon Icon="@Icon" Color="Color.Secondary" Size="Size.Medium" />
        <MudText Typo="Typo.h2" Color="Color.Secondary">
            @Title
        </MudText>
    </MudStack>
    <CatsBreadcrumbs Items="@Items" />
</MudStack>

@code{

    [Parameter, EditorRequired]
    public string Title { get; set; }

    [Parameter, EditorRequired]
    public IReadOnlyList<BreadcrumbItem> Items { get;set; }

    [Parameter, EditorRequired]
    public string Icon { get; set; }

}