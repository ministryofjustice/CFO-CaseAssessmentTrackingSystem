@using Amazon.Runtime.Credentials.Internal
@using Cfo.Cats.Server.UI.Models.NavigationMenu
@using Cfo.Cats.Server.UI.Pages.Objectives.Tasks
@using Cfo.Cats.Server.UI.Services.Navigation
@inject IAsyncMenuService MenuService
@inject IStringLocalizer<NavigationMenu> L

<MudDrawer Breakpoint="Breakpoint.Md"
           Class="side-menu"
           Elevation="0"
           Open="DrawerOpen"
           OpenChanged="@(e => DrawerOpenChanged.InvokeAsync(e))"
           Variant="DrawerVariant.Responsive"
           Anchor="Anchor.Right"
           ClipMode="DrawerClipMode.Always">
    <MudDrawerHeader Class="align-center d-flex align-center pa-0">
        <MudText Typo="Typo.subtitle2">
            <b>@L[ApplicationSettings.AppName]</b>
        </MudText>
    </MudDrawerHeader>

    <MudNavMenu>
        @foreach (var section in MenuSections)
        {
            @if (section is not null)
            {

                <div class="ml-6 my-3">
                    <MudText Typo="Typo.caption">
                        <b>
                            @(L[section.Title])
                        </b>
                    </MudText>
                </div>


                @if (section.SectionItems is not null)
                {
                    foreach (MenuSectionItemModel sectionItem in section.SectionItems)
                    {
                        @if (sectionItem is { IsParent: true, MenuItems: not null })
                        {
                            <MudNavGroup Icon="@sectionItem.Icon" Title="@L[sectionItem.Title]" Expanded="Expanded(sectionItem)">
                                @foreach (var menuItem in sectionItem.MenuItems)
                                {
                                    <MudNavLink Href="@(menuItem.Href)" Target="@(menuItem.Target)" Match="NavLinkMatch.All" Disabled="@(menuItem.PageStatus == PageStatus.ComingSoon)" >
                                        <div class="d-flex">
                                            @(L[menuItem.Title])
                                            @if (menuItem.PageStatus != PageStatus.Completed)
                                            {
                                                <MudSpacer/>
                                                <MudChip T="string" Class="mr-4" Color="@Color.Primary" Size="Size.Small" Variant="Variant.Text">
                                                    @(L[menuItem.PageStatus.GetDescription()])
                                                </MudChip>
                                            }
                                        </div>
                                    </MudNavLink>
                                }
                            </MudNavGroup>
                        }
                        else
                        {
                            <MudNavLink Href="@(sectionItem.Href)" Icon="@(sectionItem.Icon)" Match="NavLinkMatch.All" Disabled="@(sectionItem.PageStatus == PageStatus.ComingSoon)">
                                <div class="d-flex">
                                    @(L[sectionItem.Title])
                                    @if (sectionItem.PageStatus != PageStatus.Completed)
                                    {
                                        <MudSpacer/>
                                        <MudChip T="string" Class="mr-4" Color="@Color.Primary" Size="Size.Small" Variant="Variant.Text">
                                            @(L[sectionItem.PageStatus.GetDescription()])
                                        </MudChip>
                                    }
                                </div>
                            </MudNavLink>
                        }
                    }
                }
            }
        }

    </MudNavMenu>
    
    <MudDivider Class="mt-auto"></MudDivider>
    <MudNavMenu Class="d-flex justify-space-between pa-4">
        <MudLink Href="#" Style="font-size:0.625rem;line-height:1.125rem;color:#6F6F6F !important">@L[ApplicationSettings.Copyright]</MudLink>
        <MudText Class="" Style="font-size:0.625rem;line-height:1.125rem;color:#6F6F6F !important">@L["version"] @ApplicationSettings.Version</MudText>
    </MudNavMenu>

</MudDrawer>



<style>
        .mud-nav-link.active:not(.mud-nav-link-disabled) {
            border-right: 3px solid var(--mud-palette-primary);
        }

        .side-menu {
            border-right: 1px solid var(--mud-palette-table-lines)
        }
    </style>

@code
{
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = default!;
    [EditorRequired] [Parameter] public EventCallback<bool> DrawerOpenChanged { get; set; }

    [EditorRequired] [Parameter] public bool DrawerOpen { get; set; }

    private IEnumerable<MenuSectionModel> MenuSections = [];
    [EditorRequired] [Parameter] public string[] Roles { get; set; } = Array.Empty<string>();


    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState;
        MenuSections = await MenuService.GetFeaturesAsync(authState.User);
    }

    private bool Expanded(MenuSectionItemModel menu)
    {
        var href = Navigation.Uri[(Navigation.BaseUri.Length - 1)..];
        return menu is { IsParent: true, MenuItems: not null } &&
               menu.MenuItems.Any(x => !string.IsNullOrEmpty(x.Href) && x.Href.Equals(href));
    }
}