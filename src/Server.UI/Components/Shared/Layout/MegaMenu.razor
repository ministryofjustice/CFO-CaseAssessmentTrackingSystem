@using Cfo.Cats.Server.UI.Models.NavigationMenu
@inject IStringLocalizer<HeaderMenu> L
@inherits CatsComponentBase

@if (Open)
{
    <MudOverlay Visible="true" AutoClose="true" OnClosed="CloseAsync" LockScroll="false" />
    <MudPaper Elevation="4" Square="true" Class="pa-0">
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-6" Style="background-color: rgb(0,0,0, 0.02)">
            <MudGrid Spacing="6" Class="mt-2">
                @foreach (var section in _menuModel.Sections)
                {
                    <MudItem xs="12" sm="6" md="4" lg="3">
                        <MudText Typo="Typo.h2" Class="mb-2">@L[section.Title]</MudText>
                        <MudDivider Class="mb-3" />
                        <MudStack Spacing="2" AlignItems="AlignItems.Start">

                        @foreach (var item in section.Links)
                        {
                            if(item is NavigationMenuItemLinkModel link)
                            {
                                @if (section.IsBookmarkable)
                                {
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Style="width: 100%;">
                                        <MudLink
                                            Href="@link.Href"
                                            Target="@link.Target"
                                            aria-description="@link.AccessibilityText"
                                            Class="pa-1"
                                            Underline="Underline.Always">
                                            @L[@link.DisplayText]
                                        </MudLink>
                                        <MudIconButton 
                                            Icon="@(link.Href == _defaultWorkspace ? Icons.Material.Filled.Star : Icons.Material.Outlined.StarBorder)"
                                            Color="@(link.Href == _defaultWorkspace ? Color.Warning : Color.Default)"
                                            Size="Size.Small"
                                            OnClick="@(async () => await ToggleWorkspaceBookmark(link.Href!))"
                                            aria-label="@(link.Href == _defaultWorkspace ? "Remove bookmark" : "Set as default workspace")" />
                                    </MudStack>
                                }
                                else
                                {
                                    <MudLink
                                        Href="@link.Href"
                                        Target="@link.Target"
                                        aria-description="@link.AccessibilityText"
                                        Class="pa-1"
                                        Underline="Underline.Always">
                                        @L[@link.DisplayText]
                                    </MudLink>
                                }
                            }

                            if(item is NavigationMenuItemButtonModel button)
                            {
                                <MudButton 
                                    Href="@button.Href"
                                    aria-description="@button.AccessibilityText"
                                    Class="pa-1"
                                    Variant="Variant.Filled"
                                    Color="@button.Colour.AsMudColour()">
                                    @button.DisplayText
                                </MudButton>
                            }

                            if(item is NavigationMenuItemDividerModel)
                            {
                                <MudDivider />
                            }

                        }
                        </MudStack>
                    </MudItem>
                }
                <MudItem xs="12">
                    <MudStack Row="true">
                        <MudSpacer />
                        <MudLink Href="#" Style="font-size:0.625rem;line-height:1.125rem;color:#6F6F6F !important">@L[ApplicationSettings.Copyright]</MudLink>
                        <MudText Class="" Style="font-size:0.625rem;line-height:1.125rem;color:#6F6F6F !important">@L["version"] @ApplicationSettings.Version</MudText>
                    </MudStack>
                </MudItem>
            </MudGrid>
        </MudContainer>
    </MudPaper>
}
