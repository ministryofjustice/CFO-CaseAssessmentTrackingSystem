@using Cfo.Cats.Application.Features.Delius.DTOs
@using Cfo.Cats.Server.UI.Models.NavigationMenu
@inject IStringLocalizer<HeaderMenu> L

@if (Open)
{
    <MudPaper Elevation="4" Square="true" Class="pa-0">
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-6">
            <MudText Typo="Typo.h2">
                Menu
            </MudText>
            <MudGrid Spacing="6" Class="mt-2">
                @foreach (var section in _menuModel.Sections)
                {
                    <MudItem xs="12" sm="6" md="4" lg="3">
                        <MudText Typo="Typo.h3" Class="mb-2" Color="Color.Primary">@L[section.Title]</MudText>
                        <MudDivider Class="mb-3" />
                        <MudStack Spacing="2" AlignItems="AlignItems.Start">

                        
                        @foreach (var item in section.Links)
                        {
                            if(item is NavigationMenuItemLinkModel link)
                            {
                                <MudLink
                                    Href="@link.Href"
                                    Target="@link.Target"
                                    aria-description="@link.AccessbilityText"
                                    Class="pa-1"
                                    Underline="Underline.Always"
                                    Color="Color.Default">
                                    @L[@link.DisplayText]
                                </MudLink>
                            }

                            if(item is NavigationMenuItemButtonModel button)
                            {
                                <MudButton 
                                    Href="@button.Href"
                                    aria-description="@button.AccessibilityText"
                                    Class="pa-1"
                                    Variant="Variant.Filled"
                                    Color="@button.Colour.AsMudColour()">
                                    @button.DisplayText
                                </MudButton>
                            }

                            if(item is NavigationMenuItemDividerModel)
                            {
                                <MudDivider />
                            }

                        }
                        </MudStack>
                    </MudItem>
                }
            </MudGrid>
        </MudContainer>
    </MudPaper>
}

@code
{
    private RenderFragment? RenderStatus(PageStatus status) => status == PageStatus.Completed
        ? null
        : @<MudChip T="string" Size="Size.Small" Color="@StatusColour(status)" Variant="Variant.Filled">@status.GetDescription()</MudChip>;

    private static Color StatusColour(PageStatus status) => status switch
    {
        PageStatus.Wip => Color.Warning,
        PageStatus.New => Color.Success,
        PageStatus.ComingSoon => Color.Default,
        _ => Color.Default
    };
}
