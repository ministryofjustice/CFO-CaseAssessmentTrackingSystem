@using Cfo.Cats.Application.SecurityConstants
@using Toolbelt.Blazor.HotKeys2
@inject IStringLocalizer<SharedResource> L
@inject HotKeys HotKeys
@inject NavigationManager Navigation

<MudDialog>
    <DialogContent>
        <MudContainer>
            <MudFocusTrap>
                <MudTextField @bind-Value="@_search"
                Class="mb-3"
                Clearable="true" 
                Placeholder="@L["Search..."]"
                TextChanged="@(SearchPages)"
                Immediate="true"
                @onkeydown="HandleTextFieldKeyDown" />
                <MudList T="string" ReadOnly="false"
                Style="height: 300px; overflow-y: auto">
                    @foreach (var (key, value) in _pagesFiltered)
                    {
                        <MudListItem T="string" OnClick="@(() => Navigation.NavigateTo(value))" @onkeypress="@(e => HandleListItemKeyDown(e, value))">
                            <MudHighlighter HighlightedText="@_search"
                            Text="@key"/>
                        </MudListItem>
                    }
                </MudList>
            </MudFocusTrap>
        </MudContainer>
    </DialogContent>
</MudDialog>

