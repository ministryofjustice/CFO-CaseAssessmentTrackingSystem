@inherits CatsComponent<Cfo.Cats.Application.Features.InnovationFunds.DTOs.InnovationFundDto[]>

@if (ErrorMessage is not null)
{
    <MudAlert Variant="Variant.Filled" Severity="Severity.Error">
        @ErrorMessage
    </MudAlert>
}

@if (Data is not null)
{
    <MudTable Items="@Data"
              Hover="true"
              Striped="true"
              Dense="true"
              SortLabel="Sort By">
        <ToolBarContent>
            <MudText Typo="Typo.h6">Innovation Funds</MudText>
            <MudSpacer />
            <MudButton Variant="Variant.Filled"
                       Size="Size.Small"
                       Disabled="@Loading"
                       OnClick="@(() => OnAdd())"
                       StartIcon="@Icons.Material.Filled.Add"
                       Color="Color.Primary">
                Add Innovation Fund
            </MudButton>
        </ToolBarContent>
        <HeaderContent>
            <MudTh></MudTh>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<InnovationFundDto, object>(x => x.Code)">Code</MudTableSortLabel>
            </MudTh>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<InnovationFundDto, object>(x => x.Description)">Description</MudTableSortLabel>
            </MudTh>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<InnovationFundDto, object>(x => x.Contract)">Contract</MudTableSortLabel>
            </MudTh>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<InnovationFundDto, object>(x => x.LifetimeStart)">Start Date</MudTableSortLabel>
            </MudTh>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<InnovationFundDto, object>(x => x.LifetimeEnd)">End Date</MudTableSortLabel>
            </MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                <MudMenu Icon="@Icons.Material.Filled.Edit" Variant="Variant.Filled" Size="Size.Small"
                         Dense="true"
                         EndIcon="@Icons.Material.Filled.KeyboardArrowDown" IconColor="Color.Info" AnchorOrigin="Origin.CenterLeft">
                    <MudMenuItem OnClick="@(() => OnEdit(context))">
                        @ConstantString.Edit
                    </MudMenuItem>
                </MudMenu>
            </MudTd>
            <MudTd DataLabel="Code">@context.Code</MudTd>
            <MudTd DataLabel="Description">@context.Description</MudTd>
            <MudTd DataLabel="Contract">@context.Contract</MudTd>
            <MudTd DataLabel="Start Date">@context.LifetimeStart.ToShortDateString()</MudTd>
            <MudTd DataLabel="End Date">@context.LifetimeEnd.ToShortDateString()</MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
}
